# pnpm configuration
# Equivalent to .yarnrc.yml settings

# Store location (local, not global)
store-dir=~/.pnpm-store

# Use pnpm's default isolated node_modules (strict dependency resolution)
# Note: If dependency issues arise, see PR #7401 for fixes when avoiding hoisting
# node-linker=hoisted  # Commented out to use pnpm's default isolated mode
