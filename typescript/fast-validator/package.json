{
  "name": "@hyperlane-xyz/fast-validator",
  "version": "35.0.0",
  "private": true,
  "description": "Stateless cross-chain Hyperlane validator that signs checkpoints on-demand via an HTTP API",
  "homepage": "https://www.hyperlane.xyz",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hyperlane-xyz/hyperlane-monorepo"
  },
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf ./dist",
    "start": "node dist/src/scripts/run-server.js",
    "start:dev": "NODE_ENV=development LOG_FORMAT=pretty tsx src/scripts/run-server.ts",
    "announce": "tsx src/scripts/announce.ts",
    "lint": "oxlint -c ../../oxlint.json",
    "format": "oxfmt --write ./src ./test",
    "test": "pnpm test:unit",
    "test:ci": "pnpm test",
    "test:unit": "mocha --config .mocharc.json './test/**/*.ts' --exit"
  },
  "dependencies": {
    "@hyperlane-xyz/utils": "workspace:*",
    "ethers": "catalog:",
    "express": "^5.1.0",
    "pino": "catalog:",
    "yaml": "catalog:",
    "yargs": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@hyperlane-xyz/tsconfig": "workspace:^",
    "@types/chai": "catalog:",
    "@types/express": "^5.0.3",
    "@types/mocha": "catalog:",
    "@types/node": "catalog:",
    "@types/yargs": "catalog:",
    "chai": "catalog:",
    "mocha": "catalog:",
    "oxfmt": "catalog:",
    "pino-pretty": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
