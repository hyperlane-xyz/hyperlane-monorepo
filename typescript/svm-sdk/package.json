{
  "name": "@hyperlane-xyz/sealevel-sdk",
  "version": "31.2.1",
  "description": "Hand-crafted Solana/SVM client for Hyperlane Sealevel programs",
  "keywords": [
    "hyperlane",
    "sealevel",
    "solana",
    "svm"
  ],
  "homepage": "https://www.hyperlane.xyz",
  "license": "Apache-2.0",
  "repository": "https://github.com/hyperlane-xyz/hyperlane-monorepo",
  "files": [
    "/dist"
  ],
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf ./dist && tsc && cp -r ./src/testing/fixtures ./dist/testing/fixtures",
    "program:build": "(cd ../../rust/sealevel/programs && bash build-programs.sh)",
    "program:generate": "node scripts/generate-program-bytes.mjs",
    "program:check": "node scripts/check-program-bytes-hash.mjs",
    "format": "oxfmt --write ./src",
    "lint": "oxlint -c ../../oxlint.json",
    "clean": "rm -rf ./dist ./cache",
    "dev": "tsc --watch",
    "test": "pnpm test:unit",
    "test:e2e": "./scripts/run-e2e-test.sh",
    "test:unit": "mocha --require tsx --timeout 10000 'src/tests/**/*.unit-test.ts'"
  },
  "dependencies": {
    "@hyperlane-xyz/provider-sdk": "workspace:*",
    "@hyperlane-xyz/utils": "workspace:*",
    "@noble/hashes": "^1.7.1",
    "@solana-program/loader-v3": "^0.3.0",
    "@solana-program/system": "^0.12.0",
    "@solana/errors": "^6.1.0",
    "@solana/kit": "catalog:"
  },
  "devDependencies": {
    "@hyperlane-xyz/tsconfig": "workspace:^",
    "@types/chai": "^4.3.14",
    "@types/chai-as-promised": "catalog:",
    "@types/mocha": "^10.0.6",
    "@types/node": "catalog:",
    "@types/sinon": "catalog:",
    "chai": "^4.4.1",
    "chai-as-promised": "catalog:",
    "mocha": "^10.4.0",
    "mocha-steps": "catalog:",
    "oxfmt": "catalog:",
    "sinon": "catalog:",
    "testcontainers": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
