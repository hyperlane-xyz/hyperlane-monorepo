    "eslint-plugin-react": "^7.37.2",
    "react": "^18.2.0",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "^18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
