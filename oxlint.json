{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "typescript", "unicorn", "jest"],
  "options": {
    "typeAware": true
  },
  "categories": {
    "correctness": "error"
  },
  "env": {
    "builtin": true,
    "es2018": true,
    "browser": true,
    "node": true
  },
  "ignorePatterns": [
    "**/node_modules",
    "**/dist",
    "**/bundle",
    "**/coverage",
    "**/*.cjs",
    "**/*.cts",
    "**/*.mjs",
    "jest.config.js",
    "solidity/**"
  ],
  "rules": {
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_"
      }
    ],
    "import/no-named-as-default": "warn",
    "import/no-duplicates": "warn",
    "@typescript-eslint/no-require-imports": "warn",
    "import/no-cycle": "off",
    "guard-for-in": "error",
    "import/no-self-import": "error",
    "no-console": "error",
    "no-eval": "error",
    "no-restricted-imports": [
      "error",
      {
        "name": "console",
        "message": "Please use a logger and/or the utils package assert"
      }
    ],
    "jest/no-disabled-tests": "warn",
    "jest/no-focused-tests": "error",
    "jest/no-identical-title": "error",
    "jest/prefer-to-have-length": "warn",
    "jest/valid-expect": "error",
    "jest/expect-expect": [
      "warn",
      {
        "assertFunctionNames": [
          "expect",
          "assert",
          "verifyImport",
          "runGitleaksSuccessTest",
          "runGitleaksFailureTest",
          "sinon.assert.*",
          "**.expectEmpty",
          "**.expectViolations",
          "request.**.expect"
        ]
      }
    ],
    "jest/valid-title": "off",
    "jest/valid-describe-callback": "warn",
    "jest/no-conditional-expect": "warn",
    "jest/no-export": "warn",

    "@typescript-eslint/no-floating-promises": "error",
    "@typescript-eslint/await-thenable": "error",
    "@typescript-eslint/no-for-in-array": "error",
    "@typescript-eslint/no-implied-eval": "error",
    "@typescript-eslint/no-unnecessary-type-assertion": "error",
    "@typescript-eslint/restrict-plus-operands": "error",
    "@typescript-eslint/restrict-template-expressions": "error",
    "@typescript-eslint/unbound-method": "error",
    "@typescript-eslint/no-base-to-string": "error",
    "@typescript-eslint/only-throw-error": "error",
    "@typescript-eslint/prefer-promise-reject-errors": "error",
    "@typescript-eslint/no-duplicate-type-constituents": "error",
    "@typescript-eslint/no-redundant-type-constituents": "error",
    "@typescript-eslint/consistent-type-imports": "off",
    "@typescript-eslint/require-await": "off",
    "@typescript-eslint/no-misused-promises": "off",
    "@typescript-eslint/no-unsafe-argument": "off",
    "@typescript-eslint/no-unsafe-assignment": "off",
    "@typescript-eslint/no-unsafe-call": "off",
    "@typescript-eslint/no-unsafe-enum-comparison": "off",
    "@typescript-eslint/no-unsafe-member-access": "off",
    "@typescript-eslint/no-unsafe-return": "off",
    "@typescript-eslint/require-array-sort-compare": "off",
    "@typescript-eslint/no-misused-spread": "off"
  },
  "globals": {
    "AudioWorkletGlobalScope": "readonly",
    "AudioWorkletProcessor": "readonly",
    "currentFrame": "readonly",
    "currentTime": "readonly",
    "registerProcessor": "readonly",
    "sampleRate": "readonly",
    "WorkletGlobalScope": "readonly"
  },
  "overrides": [
    {
      "files": [
        "**/*.test.ts",
        "**/*.spec.ts",
        "**/*-test.ts",
        "**/test/**",
        "**/tests/**",
        "typescript/rebalancer/src/e2e/**"
      ],
      "rules": {
        "no-console": "off",
        "no-unused-expressions": "off"
      }
    },
    {
      "files": [
        "typescript/infra/**/*.ts",
        "typescript/cli/**/*.ts",
        "typescript/ccip-server/**/*.ts",
        "**/scripts/**",
        "**/*.stories.tsx"
      ],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["**/scripts/**", "typescript/infra/src/**/*.ts"],
      "rules": {
        "@typescript-eslint/no-floating-promises": "off"
      }
    },
    {
      "files": [
        "typescript/sdk/src/**/*.ts",
        "typescript/widgets/src/**/*.ts",
        "typescript/utils/src/**/*.ts"
      ],
      "rules": {
        "import/no-nodejs-modules": "warn",
        "no-restricted-imports": [
          "warn",
          {
            "paths": [
              {
                "name": "fs",
                "message": "Avoid Node.js built-in modules in browser-targeted packages. Use environment-agnostic alternatives."
              },
              {
                "name": "path",
                "message": "Avoid Node.js built-in modules in browser-targeted packages. Use environment-agnostic alternatives."
              },
              {
                "name": "child_process",
                "message": "Avoid Node.js built-in modules in browser-targeted packages. Use environment-agnostic alternatives."
              },
              {
                "name": "os",
                "message": "Avoid Node.js built-in modules in browser-targeted packages. Use environment-agnostic alternatives."
              },
              {
                "name": "http",
                "message": "Avoid Node.js built-in modules in browser-targeted packages. Use environment-agnostic alternatives."
              },
              {
                "name": "https",
                "message": "Avoid Node.js built-in modules in browser-targeted packages. Use environment-agnostic alternatives."
              },
              {
                "name": "net",
                "message": "Avoid Node.js built-in modules in browser-targeted packages. Use environment-agnostic alternatives."
              },
              {
                "name": "dgram",
                "message": "Avoid Node.js built-in modules in browser-targeted packages. Use environment-agnostic alternatives."
              },
              {
                "name": "dns",
                "message": "Avoid Node.js built-in modules in browser-targeted packages. Use environment-agnostic alternatives."
              },
              {
                "name": "tls",
                "message": "Avoid Node.js built-in modules in browser-targeted packages. Use environment-agnostic alternatives."
              },
              {
                "name": "cluster",
                "message": "Avoid Node.js built-in modules in browser-targeted packages. Use environment-agnostic alternatives."
              },
              {
                "name": "vm",
                "message": "Avoid Node.js built-in modules in browser-targeted packages. Use environment-agnostic alternatives."
              },
              {
                "name": "readline",
                "message": "Avoid Node.js built-in modules in browser-targeted packages. Use environment-agnostic alternatives."
              }
            ]
          }
        ]
      }
    },
    {
      "files": [
        "typescript/utils/src/fs/**/*.ts",
        "typescript/utils/src/eslint-rules/**/*.ts",
        "typescript/sdk/src/**/*.test.ts",
        "typescript/sdk/src/**/*.spec.ts",
        "typescript/sdk/src/**/*-test.ts",
        "typescript/widgets/src/**/*.test.ts",
        "typescript/widgets/src/**/*.spec.ts",
        "typescript/widgets/src/**/*-test.ts",
        "typescript/utils/src/**/*.test.ts",
        "typescript/utils/src/**/*.spec.ts",
        "typescript/utils/src/**/*-test.ts"
      ],
      "rules": {
        "import/no-nodejs-modules": "off",
        "no-restricted-imports": "off"
      }
    },
    {
      "files": [
        "typescript/aleo-sdk/src/**/*.ts",
        "typescript/ccip-server/src/**/*.ts",
        "typescript/cli/src/**/*.ts",
        "typescript/cosmos-sdk/src/**/*.ts",
        "typescript/github-proxy/**/*.ts",
        "typescript/helloworld/src/**/*.ts",
        "typescript/http-registry-server/**/*.ts",
        "typescript/infra/**/*.ts",
        "typescript/radix-sdk/src/**/*.ts",
        "typescript/rebalancer/src/**/*.ts",
        "typescript/rebalancer-sim/src/**/*.ts",
        "typescript/sdk/src/**/*.ts",
        "typescript/svm-sdk/src/**/*.ts",
        "typescript/tron-sdk/src/**/*.ts",
        "typescript/utils/src/**/*.ts",
        "typescript/widgets/src/**/*.{ts,tsx}",
        "starknet/**/*.ts"
      ],
      "rules": {
        "@typescript-eslint/await-thenable": "off",
        "@typescript-eslint/no-base-to-string": "off",
        "@typescript-eslint/no-duplicate-type-constituents": "off",
        "@typescript-eslint/no-unnecessary-type-assertion": "off",
        "@typescript-eslint/no-redundant-type-constituents": "off",
        "@typescript-eslint/only-throw-error": "off",
        "@typescript-eslint/prefer-promise-reject-errors": "off",
        "@typescript-eslint/restrict-template-expressions": "off",
        "@typescript-eslint/unbound-method": "off"
      }
    },
    {
      "files": ["typescript/relayer/src/**/*.ts"],
      "rules": {
        "@typescript-eslint/no-base-to-string": "off",
        "@typescript-eslint/restrict-template-expressions": "off"
      }
    },
    {
      "files": [
        "typescript/cli/**/*.ts",
        "typescript/svm-sdk/src/**/*.ts",
        "typescript/cosmos-sdk/src/**/*.ts",
        "typescript/aleo-sdk/src/**/*.ts"
      ],
      "rules": {
        "@typescript-eslint/consistent-type-imports": [
          "error",
          {
            "prefer": "type-imports",
            "fixStyle": "inline-type-imports"
          }
        ]
      }
    }
  ]
}
