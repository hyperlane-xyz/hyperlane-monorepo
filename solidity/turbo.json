{
  "extends": ["//"],
  "tasks": {
    "deps:soldeer": {
      "inputs": ["foundry.toml", "soldeer.lock"],
      "outputs": ["dependencies/**"]
    },
    "build": {
      "dependsOn": ["deps:soldeer"],
      "outputs": [
        "artifacts/**",
        "cache/**",
        "core-utils/**",
        "dist/**",
        "types/**"
      ]
    },
    "build:paris": {
      "dependsOn": ["build"],
      "inputs": [
        "contracts/**",
        "paris-hardhat.config.cts",
        "rootHardhatConfig.cts",
        "tsconfig.paris-typechain.json",
        "fix-typechain-ethers.mjs"
      ],
      "outputs": [
        "artifacts-paris/**",
        "cache-paris/**",
        "dist/paris/**"
      ]
    }
  }
}
