{
  "name": "@hyperlane-xyz/multicollateral",
  "description": "TokenBridgeOft typechain compatibility package for Hyperlane",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./typechain": "./dist/typechain/index.js",
    "./typechain/*": "./dist/typechain/*"
  },
  "files": [
    "/dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://www.hyperlane.xyz",
  "repository": "https://github.com/hyperlane-xyz/hyperlane-monorepo",
  "keywords": [
    "Hyperlane",
    "Solidity",
    "TokenBridgeOft"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.json",
    "clean": "rm -rf ./artifacts ./cache ./dist ./forge-cache ./out",
    "lint": "eslint -c ./eslint.config.mjs ./index.ts ./typechain/**/*.ts"
  },
  "dependencies": {
    "@hyperlane-xyz/core": "workspace:*"
  },
  "devDependencies": {
    "@typechain/ethers-v5": "catalog:",
    "typechain": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@ethersproject/abi": "*",
    "@ethersproject/providers": "*"
  }
}
