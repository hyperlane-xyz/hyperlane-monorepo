{
  "name": "@hyperlane-xyz/multicollateral",
  "description": "MultiCollateral solidity contracts and viem artifacts for Hyperlane",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./generated": "./dist/generated/index.js",
    "./generated/*": "./dist/generated/*",
    "./contracts": "./contracts",
    "./contracts/*": "./contracts/*"
  },
  "files": [
    "/dist",
    "/contracts"
  ],
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://www.hyperlane.xyz",
  "repository": "https://github.com/hyperlane-xyz/hyperlane-monorepo",
  "keywords": [
    "Hyperlane",
    "Solidity",
    "MultiCollateral"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "deps:soldeer": "[ -d ../dependencies/@openzeppelin-contracts-4.9.3 ] || pnpm -C ../ deps:soldeer",
    "build": "pnpm clean && pnpm deps:soldeer && forge build && node generate-contract-factories.mjs && tsc -p tsconfig.json",
    "clean": "rm -rf ./artifacts ./cache ./dist ./generated ./forge-cache ./out",
    "lint": "eslint -c ./eslint.config.mjs ./index.ts",
    "test": "pnpm deps:soldeer && forge test -vvv",
    "test:ci": "pnpm test"
  },
  "dependencies": {
    "@hyperlane-xyz/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "viem": "catalog:"
  },
  "peerDependencies": {}
}
